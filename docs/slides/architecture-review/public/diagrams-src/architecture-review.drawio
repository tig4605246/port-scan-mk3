        <mxCell id="R04-N12" value="speedctrl moves gate to stop" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#fff2d8;strokeColor=#b45309;fontSize=14;" vertex="1" parent="1"><mxGeometry x="420" y="440" width="250" height="100" as="geometry"/></mxCell>
        <mxCell id="R04-N13" value="scanapp persists resume snapshot" style="shape=document;whiteSpace=wrap;html=1;fillColor=#eee5ff;strokeColor=#7c3aed;fontSize=14;" vertex="1" parent="1"><mxGeometry x="740" y="445" width="270" height="90" as="geometry"/></mxCell>
        <mxCell id="R04-N14" value="Operator reruns with -resume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dff6f3;strokeColor=#0d9488;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1080" y="445" width="240" height="90" as="geometry"/></mxCell>

        <mxCell id="R04-N21" value="Failure branch C&#xa;SIGINT / cancellation" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fde2e2;strokeColor=#b91c1c;fontSize=14;" vertex="1" parent="1"><mxGeometry x="100" y="730" width="220" height="110" as="geometry"/></mxCell>
        <mxCell id="R04-N22" value="Graceful stop boundary&#xa;drain, checkpoint, exit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#b91c1c;fontSize=14;" vertex="1" parent="1"><mxGeometry x="390" y="740" width="280" height="90" as="geometry"/></mxCell>
        <mxCell id="R04-N23" value="resume_state.json or explicit -resume path" style="shape=document;whiteSpace=wrap;html=1;fillColor=#eee5ff;strokeColor=#7c3aed;fontSize=14;" vertex="1" parent="1"><mxGeometry x="740" y="745" width="320" height="90" as="geometry"/></mxCell>
        <mxCell id="R04-N24" value="Next run restores progress deterministically" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dff6f3;strokeColor=#0d9488;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1130" y="745" width="300" height="90" as="geometry"/></mxCell>

        <mxCell id="R04-N31" value="Review takeaway&#xa;Failure modes are explicit, resumable, and externally inspectable." style="rounded=1;dashed=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#475569;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1640" y="410" width="520" height="230" as="geometry"/></mxCell>

        <mxCell id="R04-E01" value="fail fast" style="endArrow=classic;html=1;strokeColor=#b91c1c;fontSize=12;" edge="1" parent="1" source="R04-N01" target="R04-N02"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R04-E02" value="escalate" style="endArrow=classic;html=1;strokeColor=#b91c1c;fontSize=12;" edge="1" parent="1" source="R04-N11" target="R04-N12"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R04-E03" value="checkpoint" style="endArrow=classic;html=1;strokeColor=#92400e;fontSize=12;dashed=1;" edge="1" parent="1" source="R04-N12" target="R04-N13"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R04-E04" value="recover" style="endArrow=classic;html=1;strokeColor=#7c3aed;fontSize=12;dashed=1;" edge="1" parent="1" source="R04-N13" target="R04-N14"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R04-E05" value="signal" style="endArrow=classic;html=1;strokeColor=#b91c1c;fontSize=12;" edge="1" parent="1" source="R04-N21" target="R04-N22"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R04-E06" value="persist" style="endArrow=classic;html=1;strokeColor=#7c3aed;fontSize=12;dashed=1;" edge="1" parent="1" source="R04-N22" target="R04-N23"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R04-E07" value="resume" style="endArrow=classic;html=1;strokeColor=#7c3aed;fontSize=12;dashed=1;" edge="1" parent="1" source="R04-N23" target="R04-N24"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="r05" name="Trade-Off-Comparison">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="R05-N01" value="Current choice&#xa;Deterministic in-process pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dff6f3;strokeColor=#0d9488;fontSize=15;" vertex="1" parent="1"><mxGeometry x="120" y="120" width="380" height="120" as="geometry"/></mxCell>
        <mxCell id="R05-N02" value="Alternative&#xa;Distributed queue / scheduler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#c2410c;fontSize=15;" vertex="1" parent="1"><mxGeometry x="120" y="320" width="380" height="120" as="geometry"/></mxCell>
        <mxCell id="R05-N03" value="Alternative&#xa;Raw packet / SYN scan model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#c2410c;fontSize=15;" vertex="1" parent="1"><mxGeometry x="120" y="520" width="380" height="120" as="geometry"/></mxCell>

        <mxCell id="R05-N11" value="Strengths&#xa;- clear contracts&#xa;- simple deployment&#xa;- inspectable artifacts&#xa;- fits current scale" style="shape=document;whiteSpace=wrap;html=1;fillColor=#eee5ff;strokeColor=#7c3aed;fontSize=14;" vertex="1" parent="1"><mxGeometry x="620" y="110" width="300" height="160" as="geometry"/></mxCell>
        <mxCell id="R05-N12" value="Costs&#xa;- throughput ceiling stays local&#xa;- one process owns pacing logic" style="shape=document;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#b91c1c;fontSize=14;" vertex="1" parent="1"><mxGeometry x="980" y="110" width="300" height="160" as="geometry"/></mxCell>

        <mxCell id="R05-N21" value="Benefits if adopted&#xa;- elastic scaling&#xa;- separated scheduling" style="shape=document;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#c2410c;fontSize=14;" vertex="1" parent="1"><mxGeometry x="620" y="320" width="300" height="120" as="geometry"/></mxCell>
        <mxCell id="R05-N22" value="Why rejected now&#xa;- higher operational burden&#xa;- more moving parts than requirements justify" style="shape=document;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#b91c1c;fontSize=14;" vertex="1" parent="1"><mxGeometry x="980" y="300" width="340" height="160" as="geometry"/></mxCell>

        <mxCell id="R05-N31" value="Benefits if adopted&#xa;- lower-level packet control&#xa;- potentially different performance profile" style="shape=document;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#c2410c;fontSize=14;" vertex="1" parent="1"><mxGeometry x="620" y="520" width="300" height="140" as="geometry"/></mxCell>
        <mxCell id="R05-N32" value="Why rejected now&#xa;- diverges from current Go net model&#xa;- harder to validate and operate safely" style="shape=document;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#b91c1c;fontSize=14;" vertex="1" parent="1"><mxGeometry x="980" y="500" width="340" height="180" as="geometry"/></mxCell>

        <mxCell id="R05-N41" value="Review thesis&#xa;The design intentionally favors reviewability, stability, and operational clarity over speculative capability." style="rounded=1;dashed=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#475569;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1510" y="240" width="560" height="250" as="geometry"/></mxCell>

        <mxCell id="R05-E01" value="" style="endArrow=classic;html=1;strokeColor=#0d9488;" edge="1" parent="1" source="R05-N01" target="R05-N11"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R05-E02" value="" style="endArrow=classic;html=1;strokeColor=#0d9488;" edge="1" parent="1" source="R05-N01" target="R05-N12"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R05-E03" value="" style="endArrow=classic;html=1;strokeColor=#c2410c;" edge="1" parent="1" source="R05-N02" target="R05-N21"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R05-E04" value="" style="endArrow=classic;html=1;strokeColor=#c2410c;" edge="1" parent="1" source="R05-N02" target="R05-N22"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R05-E05" value="" style="endArrow=classic;html=1;strokeColor=#c2410c;" edge="1" parent="1" source="R05-N03" target="R05-N31"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="R05-E06" value="" style="endArrow=classic;html=1;strokeColor=#c2410c;" edge="1" parent="1" source="R05-N03" target="R05-N32"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
