  <diagram id="p04" name="P04-Component-Contracts">
<mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1600" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <mxCell id="P04-N01" value="&lt;b&gt;CLI/config&lt;/b&gt;&lt;br&gt;Input: flags and CLI command&lt;br&gt;Process: parse and normalize config&lt;br&gt;Output: config.Config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#334155;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="320" height="170" as="geometry"/></mxCell>
    <mxCell id="P04-N02" value="&lt;b&gt;input&lt;/b&gt;&lt;br&gt;Input: CIDR CSV, Port lines&lt;br&gt;Process: schema/containment/overlap validate + rich parse&lt;br&gt;Output: []CIDRRecord and []PortSpec" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#334155;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="400" y="80" width="330" height="170" as="geometry"/></mxCell>
    <mxCell id="P04-N03" value="&lt;b&gt;task&lt;/b&gt;&lt;br&gt;Input: validated CIDR and ports&lt;br&gt;Process: expand selectors and build execution-key dedup&lt;br&gt;Output: chunk/task descriptors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#334155;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="760" y="80" width="330" height="170" as="geometry"/></mxCell>
    <mxCell id="P04-N04" value="&lt;b&gt;scanapp&lt;/b&gt;&lt;br&gt;Input: tasks, config, control gate&lt;br&gt;Process: dispatch workers, orchestrate runtime, aggregate status&lt;br&gt;Output: writer.Record stream and chunk states" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#334155;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1120" y="80" width="340" height="170" as="geometry"/></mxCell>
    <mxCell id="P04-N05" value="&lt;b&gt;scanner&lt;/b&gt;&lt;br&gt;Input: ip, port, timeout&lt;br&gt;Process: net.DialTimeout and conn.Close on success&lt;br&gt;Output: status and response_time_ms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#334155;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1490" y="80" width="320" height="170" as="geometry"/></mxCell>

    <mxCell id="P04-N06" value="&lt;b&gt;writer&lt;/b&gt;&lt;br&gt;Input: writer.Record&lt;br&gt;Process: write full and open-only CSV&lt;br&gt;Output: scan_results-* and opened_results-*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#334155;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="400" y="320" width="330" height="170" as="geometry"/></mxCell>
    <mxCell id="P04-N07" value="&lt;b&gt;state&lt;/b&gt;&lt;br&gt;Input: chunk states&lt;br&gt;Process: save/load resume snapshots&lt;br&gt;Output: resume_state.json and restored checkpoints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#334155;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="760" y="320" width="330" height="170" as="geometry"/></mxCell>
    <mxCell id="P04-N08" value="&lt;b&gt;speedctrl&lt;/b&gt;&lt;br&gt;Input: pressure API polling and manual pause&lt;br&gt;Process: compute pause/resume gate state&lt;br&gt;Output: control signal to scanapp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#334155;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1120" y="320" width="340" height="170" as="geometry"/></mxCell>
    <mxCell id="P04-N09" value="&lt;b&gt;logx&lt;/b&gt;&lt;br&gt;Input: runtime events and status changes&lt;br&gt;Process: format human/json logs&lt;br&gt;Output: diagnostics and progress events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#334155;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1490" y="320" width="320" height="170" as="geometry"/></mxCell>

    <mxCell id="P04-N10" value="Boundary: scanner uses TCP connect semantics; not SYN/RST raw packet scan and no active RST forced teardown." style="rounded=1;dashed=1;whiteSpace=wrap;html=1;fillColor=#f4f4f5;strokeColor=#52525b;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="320" width="320" height="170" as="geometry"/></mxCell>

